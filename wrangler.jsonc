// Cloudflare Workers (static assets) — explicit config so builds are
// deterministic and wrangler skips framework auto-detection.
{
  "name": "castles-gg",
  "compatibility_date": "2026-07-02",
  "routes": [
    { "pattern": "cfworker.castles.gg", "custom_domain": true }
  ],
  "assets": {
    "directory": "./dist"
  }
}
